 RowBox[{
  RowBox[{"directions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<R\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"1", ",", "0"}], "}"}]}], ",", 
     RowBox[{"\"\<L\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "0"}], "}"}]}], ",", 
     RowBox[{"\"\<U\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}], ",", 
     RowBox[{"\"\<D\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{"-", "1"}]}], "}"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"line", "[", 
   RowBox[{"start_", ",", "dir_", ",", "steps_"}], "]"}], ":=", 
  RowBox[{"Rest", "@", 
   RowBox[{"NestList", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "+", 
       RowBox[{"(", 
        RowBox[{"dir", "/.", "directions"}], ")"}]}], "&"}], ",", "start", 
     ",", "steps"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rw1", "=", 
   RowBox[{"Fold", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "~", "Join", "~", 
       RowBox[{"line", "[", 
        RowBox[{
         RowBox[{"#1", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], "}"}], ",", 
     RowBox[{"f", "/@", "t1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rw2", "=", 
   RowBox[{"Fold", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "~", "Join", "~", 
       RowBox[{"line", "[", 
        RowBox[{
         RowBox[{"#1", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], "}"}], ",", 
     RowBox[{"f", "/@", "t2"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"wireDistance", "[", 
   RowBox[{"wire_", ",", "point_"}], "]"}], ":=", 
  RowBox[{"First", "@", 
   RowBox[{"FirstPosition", "[", 
    RowBox[{"wire", ",", "point"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"distance", "[", "point_", "]"}], ":=", 
  RowBox[{
