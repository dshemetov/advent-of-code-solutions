Cell[CellGroupData[{

Cell["Problem 4", "Subsection",ExpressionUUID->"0b67be70-0cfa-4232-954f-01ed97b6f157"],

Cell["\<\
Part (a) asks us to count all the digits with non-decreasing digits and at \
least two identical consecutive digits. \
\>", "Text",ExpressionUUID->"533a84f9-4b18-440d-896b-d0eb866e692e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "273025"}], ";", 
  RowBox[{"b", "=", "767253"}], ";", 
  RowBox[{"t", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"i", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "a", ",", "b"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "n_", "]"}], ":=", 
  RowBox[{"AnyTrue", "[", 
   RowBox[{
    RowBox[{"Length", "/@", 
     RowBox[{"(", 
      RowBox[{"Gather", "@", 
       RowBox[{"IntegerDigits", "[", "n", "]"}]}], ")"}]}], ",", 
    RowBox[{
     RowBox[{"#", "\[GreaterEqual]", "2"}], "&"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Length", "@", 
  RowBox[{"Select", "[", 
   RowBox[{"t", ",", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "#", "]"}], "&&", 
      RowBox[{
       RowBox[{"Sort", "@", 
        RowBox[{"IntegerDigits", "[", "#", "]"}]}], "==", 
       RowBox[{"IntegerDigits", "[", "#", "]"}]}]}], "&"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[201]:=",ExpressionUUID->"850bb0cf-4fd4-4e6e-b6ca-76b6f82fd375"],

Cell[BoxData["910"], "Output",
 CellLabel->
  "Out[203]=",ExpressionUUID->"2ec0b33d-ca74-4ac1-ab96-be7dcfe274fa"]
}, Open  ]],

Cell["\<\
Part (b) asks for the same digits, except that the identical consecutive \
digits cannot be part of a larger group of consecutive digits. That is, the \
number has to contain at least one run of exactly two identical digits.\
\>", "Text",ExpressionUUID->"a9a34b4c-c3fb-45e1-ad65-0a74aea31710"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=", "273025"}], ";", 
  RowBox[{"b", "=", "767253"}], ";", 
  RowBox[{"t", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"i", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "a", ",", "b"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "n_", "]"}], ":=", 
  RowBox[{"AnyTrue", "[", 
   RowBox[{
    RowBox[{"Length", "/@", 
     RowBox[{"(", 
      RowBox[{"Gather", "@", 
       RowBox[{"IntegerDigits", "[", "n", "]"}]}], ")"}]}], ",", 
    RowBox[{
     RowBox[{"#", "\[Equal]", "2"}], "&"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"Length", "@", 
  RowBox[{"Select", "[", 
   RowBox[{"t", ",", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "#", "]"}], "&&", 
      RowBox[{
       RowBox[{"Sort", "@", 
        RowBox[{"IntegerDigits", "[", "#", "]"}]}], "==", 
       RowBox[{"IntegerDigits", "[", "#", "]"}]}]}], "&"}]}], 
   "]"}]}]}], "Input",
 CellLabel->
  "In[204]:=",ExpressionUUID->"f9003bcc-1980-4e3b-869c-e172011c5a73"],

Cell[BoxData["598"], "Output",
 CellLabel->
  "Out[206]=",ExpressionUUID->"9ae7d3fc-c94a-4b90-aa78-37ecc18eac94"]
}, Open  ]]
}, Open  ]],

