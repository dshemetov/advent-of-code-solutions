Cell["\<\
Part (b) requires us to find the inputs that cause the program to generate \
the output 19690720. The inputs are the two values I switched in the \
beginning of the input. I ran into an issue with the function above using the \
same variable as the Table function below. I had to specify that the index \
variable in the Module block above is local, which fixed the issue.\
\>", "Text",ExpressionUUID->"485a7f60-0a64-427e-b612-9e082b783d66"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"noun", ",", "verb", ",", "_"}], "}"}], "=", 
   RowBox[{"First", "@", 
    RowBox[{"Select", "[", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"i", ",", "j", ",", 
            RowBox[{"f", "[", 
             RowBox[{"i", ",", "j", ",", "problemInput"}], "]"}]}], "}"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "0", ",", "99"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "0", ",", "99"}], "}"}]}], "]"}], ",", "1"}], 
       "]"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "3", "]"}], "]"}], "==", "19690720"}], "&"}]}], 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"100", "*", "noun"}], "+", "verb"}]}], "Input",
 CellLabel->
  "In[179]:=",ExpressionUUID->"dedf46b8-4fe5-407a-8058-8ef9d946c826"],

Cell[BoxData["5379"], "Output",
 CellLabel->
  "Out[180]=",ExpressionUUID->"74fc3d03-3a9c-4538-b925-51182b08942e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Problem 3", "Subsection",ExpressionUUID->"128fb939-b6f9-4eaa-923d-0f84e0285612"],

Cell["\<\
Part (a) asks us to find the closest intersection point (in Manhattan \
distance) of two random walks starting from the origin, specified in a format \
very similar to turtle graphics. \
\>", "Text",ExpressionUUID->"cdbe6f4d-2713-4857-ac19-6f516d5dcccc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"t1", ",", "t2"}], "}"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"StringSplit", "[", 
      RowBox[{"#", ",", "\"\<,\>\""}], "]"}], "&"}], "/@", 
    RowBox[{"StringSplit", "[", 
     RowBox[{
      RowBox[{
      "Import", "[", "\"\<~/Downloads/Advent2019/input3a.txt\>\"", "]"}], 
      ",", "\"\<\\n\>\""}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "entry_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"First", "[", "#", "]"}], ",", 
      RowBox[{"FromDigits", "@", 
       RowBox[{"ToExpression", "@", 
        RowBox[{"Rest", "[", "#", "]"}]}]}]}], "}"}], "&"}], "@", 
   RowBox[{"Characters", "@", "entry"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"directions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\"\<R\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"1", ",", "0"}], "}"}]}], ",", 
     RowBox[{"\"\<L\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "0"}], "}"}]}], ",", 
     RowBox[{"\"\<U\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}]}], ",", 
     RowBox[{"\"\<D\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"0", ",", 
        RowBox[{"-", "1"}]}], "}"}]}]}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"line", "[", 
   RowBox[{"start_", ",", "dir_", ",", "steps_"}], "]"}], ":=", 
  RowBox[{"Rest", "@", 
   RowBox[{"NestList", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "+", 
       RowBox[{"(", 
        RowBox[{"dir", "/.", "directions"}], ")"}]}], "&"}], ",", "start", 
     ",", "steps"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rw1", "=", 
   RowBox[{"Fold", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "~", "Join", "~", 
       RowBox[{"line", "[", 
        RowBox[{
         RowBox[{"#1", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], "}"}], ",", 
     RowBox[{"f", "/@", "t1"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rw2", "=", 
   RowBox[{"Fold", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#1", "~", "Join", "~", 
       RowBox[{"line", "[", 
        RowBox[{
         RowBox[{"#1", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{"#2", "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], "&"}], ",", 
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], "}"}], ",", 
     RowBox[{"f", "/@", "t2"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Min", "@", 
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"ManhattanDistance", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], ",", "#"}], "]"}], "&"}], ",", 
    RowBox[{"Complement", "[", 
     RowBox[{
      RowBox[{"Intersection", "[", 
       RowBox[{"rw1", ",", "rw2"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0"}], "}"}], "}"}]}], "]"}]}], "]"}]}]}], "Input",E\
xpressionUUID->"1fbb050a-a69d-4a29-aa34-7355459de612"],

Cell[BoxData["1064"], "Output",
 CellLabel->
  "Out[115]=",ExpressionUUID->"2e537097-8a9f-4a5e-aa67-f3acb6c9e46d"]
}, Open  ]],

Cell["\<\
Part (b) is similar to part (a), except the distance function is now the sum \
of the path lengths to the intersection in both walks.\
\>", "Text",ExpressionUUID->"9168b4a1-59c9-41e3-8e9e-06b574f2858e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"{", 
