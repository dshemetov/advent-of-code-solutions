Notebook[{

Cell[CellGroupData[{
Cell["Advent of Code 2019", "Subchapter",ExpressionUUID->"640b6ca3-4e1b-48b2-9d8f-25f77df7c4c3"],

Cell[CellGroupData[{

Cell["Problem 1", "Subsection",ExpressionUUID->"80c7065f-ac7c-459a-8864-3f089564d5b2"],

Cell["\<\
Part (a) asks us to apply a simple function to a list of integers.\
\>", "Text",ExpressionUUID->"6d0dcdb0-26a7-4e95-b44e-f9b4e542c994"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"t", "=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"Import", "[", 
     RowBox[{
     "\"\<~/Downloads/Advent2019/input1a.txt\>\"", ",", "\"\<CSV\>\""}], 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Fold", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"#1", "+", 
     RowBox[{"Floor", "[", 
      RowBox[{"#2", "/", "3"}], "]"}], "-", "2"}], "&"}], ",", "0", ",", 
   "t"}], "]"}]}], "Input",
 CellLabel->
  "In[172]:=",ExpressionUUID->"ce64ea12-dd16-430d-be82-fda5dc77f3ff"],

Cell[BoxData["3210097"], "Output",
 CellLabel->
  "Out[173]=",ExpressionUUID->"f6a73b8b-5bfd-4417-a46f-26e9f8da17b5"]
}, Open  ]],

Cell["\<\
Part (b) asks us to apply a function repeatedly to each integer until it \
turns negative.\
\>", "Text",ExpressionUUID->"ff17aa34-ca8b-46d1-8669-fa6841a40b1c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", "n_", "]"}], ":=", 
  RowBox[{"Total", "@", 
   RowBox[{"Most", "@", 
    RowBox[{"Rest", "@", 
     RowBox[{"NestWhileList", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Floor", "[", 
          FractionBox["#", "3"], "]"}], "-", "2"}], "&"}], ",", "n", ",", 
       RowBox[{
        RowBox[{"#", ">", "0"}], "&"}]}], 
      "]"}]}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Total", "@", 
  RowBox[{"Map", "[", 
   RowBox[{"f", ",", "t"}], "]"}]}]}], "Input",
 CellLabel->
  "In[174]:=",ExpressionUUID->"4ec78ade-86bc-4673-b42d-ad700f5462c8"],

Cell[BoxData["4812287"], "Output",
 CellLabel->
  "Out[175]=",ExpressionUUID->"1a9ca5c4-f9ce-402a-ad26-96b511385236"]
}, Open  ]],

Cell["\<\
I was curious about the nested function, so with some quick calculations I \
found an approximation that shows the asymptotic character of the function to \
be linear with coefficient 1/2.\
\>", "Text",ExpressionUUID->"b9e2bf70-734d-4cbf-958c-72e476203fd4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"m", "=", "200"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g", "[", "n_", "]"}], ":=", 
  RowBox[{"Total", "@", 
   RowBox[{"Most", "@", 
    RowBox[{"Rest", "@", 
     RowBox[{"NestWhileList", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         FractionBox["#", "3"], "-", "2"}], "&"}], ",", "n", ",", 
       RowBox[{
        RowBox[{"#", ">", "0"}], "&"}]}], 
      "]"}]}]}]}]}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Array", "[", 
      RowBox[{"f", ",", "m"}], "]"}], ",", 
     RowBox[{"Array", "[", 
      RowBox[{"g", ",", "m"}], "]"}], ",", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        FractionBox["x", "2"], "-", "11"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "m"}], "}"}]}], "]"}]}], "}"}], ",", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<Rocket Eqn\>\"", ",", "\"\<Without Floor\>\"", ",", 
      "\"\<Sum Approximation\>\""}], "}"}]}]}], "]"}]}], "Input",
 CellLabel->
  "In[115]:=",ExpressionUUID->"3ab6edf7-c6f6-49a9-8a5f-166725df565f"],

