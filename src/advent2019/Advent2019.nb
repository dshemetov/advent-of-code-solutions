    RowBox[{"rw1", ",", "point"}], "]"}], "+", 
   RowBox[{"wireDistance", "[", 
    RowBox[{"rw2", ",", "point"}], "]"}], "-", "2"}]}], "\[IndentingNewLine]", 
 RowBox[{"Min", "@", 
  RowBox[{"Map", "[", 
   RowBox[{"distance", ",", 
