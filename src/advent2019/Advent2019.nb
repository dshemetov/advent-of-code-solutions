Cell[CellGroupData[{

Cell["Problem 2", "Subsection",ExpressionUUID->"b5153f31-1fe1-4eaf-89be-63b33600da11"],

Cell["\<\
Part (a) requires us to transform the string in a manner similar to a Turing \
machine.\
\>", "Text",ExpressionUUID->"0996a809-3fe1-41a8-abba-28d8b799c486"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"problemInput", "=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"Import", "[", 
     RowBox[{
     "\"\<~/Downloads/Advent2019/input2a.txt\>\"", ",", "\"\<CSV\>\""}], 
     "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", 
   RowBox[{"noun_", ",", "verb_", ",", "input_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"i", ",", "t"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", " ", 
     RowBox[{"Set", " ", "the", " ", "inputs"}], " ", "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"t", "=", "input"}], ";", 
     RowBox[{
      RowBox[{"t", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "=", "noun"}], ";", 
     RowBox[{
      RowBox[{"t", "[", 
       RowBox[{"[", "3", "]"}], "]"}], "=", "verb"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{"Set", " ", "up", " ", "the", " ", "op", " ", "codes"}], " ", 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{"ops", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"1", "\[Rule]", "Plus"}], ",", 
        RowBox[{"2", "\[Rule]", "Times"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Grab", " ", "4", " ", "values", " ", "at", " ", "a", " ", "time", " ", 
       "and", " ", "proceed", " ", "through", " ", "until", " ", "99"}], " ", 
      "*)"}], "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "<", 
        RowBox[{
         RowBox[{"Length", "[", "t", "]"}], "-", "3"}]}], ",", 
       RowBox[{"i", "=", 
        RowBox[{"i", "+", "4"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"op", ",", "i1", ",", "i2", ",", "o"}], "}"}], "=", 
         RowBox[{"t", "[", 
          RowBox[{"[", 
           RowBox[{"i", ";;", 
            RowBox[{"i", "+", "3"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"op", "\[Equal]", "99"}], ",", 
          RowBox[{"Break", "[", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"t", "[", 
            RowBox[{"[", 
             RowBox[{"o", "+", "1"}], "]"}], "]"}], "=", 
           RowBox[{
            RowBox[{"t", "[", 
             RowBox[{"[", 
              RowBox[{"i1", "+", "1"}], "]"}], "]"}], "~", 
            RowBox[{"(", 
             RowBox[{"op", "/.", "ops"}], ")"}], "~", 
            RowBox[{"t", "[", 
             RowBox[{"[", 
              RowBox[{"i2", "+", "1"}], "]"}], "]"}]}]}]}], "]"}], ";"}]}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"t", "[", 
      RowBox[{"[", "1", "]"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{"f", "[", 
  RowBox[{"12", ",", "2", ",", "problemInput"}], "]"}]}], "Input",ExpressionUU\
ID->"d06a9cbf-ebd9-448b-8a4c-c174067bc9ab"],

Cell[BoxData["6087827"], "Output",
 CellLabel->
  "Out[178]=",ExpressionUUID->"18cab19b-21a9-4750-88cf-ae6b2117508b"]
}, Open  ]],

